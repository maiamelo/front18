# ==========================================
# ⚙️  FRONT18 — .env de PRODUÇÃO (cPanel)
# ==========================================
# INSTRUÇÃO: renomeie este arquivo para .env
# e preencha com as credenciais reais.
# ==========================================

APP_NAME=Front18
APP_ENV=production
APP_URL=https://SEU_DOMINIO_AQUI.com.br
PORT=3000

# ==========================================
# 💾  MYSQL — Credenciais do cPanel
# ==========================================
# Encontre em: cPanel > MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=SEU_USUARIO_MYSQL_CPANEL
DB_PASSWORD=SUA_SENHA_MYSQL
DB_NAME=NOME_DO_BANCO_CPANEL

# ==========================================
# 🔐  SEGURANÇA
# ==========================================
# Gere um token forte em: https://randomkeygen.com
JWT_SECRET=TROQUE_POR_UM_TOKEN_SEGURO_LONGO_AQUI
FRONTEND_CDN_URL=https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js
